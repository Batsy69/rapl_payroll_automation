{
  "doctype": "DocType",
  "name": "RAPL Late Mark Processing Entry",
  "module": "RAPL Payroll Automation",
  "istable": 1,
  "editable_grid": 1,
  "engine": "InnoDB",
  "field_order": [
    "employee",
    "employee_name",
    "late_fraction_total",
    "per_day_rate",
    "column_break_amt",
    "amount",
    "additional_salary"
  ],
  "fields": [
    {
      "fieldname": "employee",
      "fieldtype": "Link",
      "label": "Employee",
      "options": "Employee",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "employee_name",
      "fieldtype": "Data",
      "label": "Employee Name",
      "fetch_from": "employee.employee_name",
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "late_fraction_total",
      "fieldtype": "Float",
      "label": "Fraction Total",
      "precision": "4",
      "in_list_view": 1,
      "description": "Editable. Changing this recalculates Amount = Fraction Total \u00d7 Per-Day Rate automatically."
    },
    {
      "fieldname": "per_day_rate",
      "fieldtype": "Currency",
      "label": "Per-Day Rate",
      "in_list_view": 1,
      "description": "Editable. Changing this recalculates Amount = Fraction Total \u00d7 Per-Day Rate automatically."
    },
    {
      "fieldname": "column_break_amt",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "amount",
      "fieldtype": "Currency",
      "label": "Amount",
      "reqd": 1,
      "in_list_view": 1,
      "description": "Auto-recalculated from Fraction Total \u00d7 Per-Day Rate whenever either changes. You can also edit Amount directly -- doing so does NOT change Fraction Total/Per-Day Rate back (one-way)."
    },
    {
      "fieldname": "additional_salary",
      "fieldtype": "Link",
      "label": "Additional Salary (after processing)",
      "options": "Additional Salary",
      "read_only": 1
    }
  ],
  "permissions": []
}
