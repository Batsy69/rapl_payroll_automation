{
  "doctype": "DocType",
  "name": "RAPL Late Mark Processing Entry",
  "module": "RAPL Payroll Automation",
  "istable": 1,
  "editable_grid": 1,
  "engine": "InnoDB",
  "field_order": [
    "employee",
    "employee_name",
    "band_1_count",
    "band_2_count",
    "band_3_count",
    "band_4_count",
    "band_5_count",
    "column_break_amt",
    "per_day_rate",
    "amount",
    "additional_salary"
  ],
  "fields": [
    {
      "fieldname": "employee",
      "fieldtype": "Link",
      "label": "Employee",
      "options": "Employee",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "employee_name",
      "fieldtype": "Data",
      "label": "Employee Name",
      "fetch_from": "employee.employee_name",
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "band_1_count",
      "fieldtype": "Int",
      "label": "Band 1",
      "default": "0",
      "in_list_view": 1,
      "description": "Count of occurrences in Late Mark Band #1 (as configured in RAPL Payroll Automation Settings). Column label is renamed at runtime to match that band's actual Label -- this generic name is only the underlying fieldname."
    },
    {
      "fieldname": "band_2_count",
      "fieldtype": "Int",
      "label": "Band 2",
      "default": "0",
      "in_list_view": 1
    },
    {
      "fieldname": "band_3_count",
      "fieldtype": "Int",
      "label": "Band 3",
      "default": "0",
      "in_list_view": 1
    },
    {
      "fieldname": "band_4_count",
      "fieldtype": "Int",
      "label": "Band 4",
      "default": "0",
      "in_list_view": 1
    },
    {
      "fieldname": "band_5_count",
      "fieldtype": "Int",
      "label": "Band 5",
      "default": "0",
      "in_list_view": 1
    },
    {
      "fieldname": "column_break_amt",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "per_day_rate",
      "fieldtype": "Currency",
      "label": "Per-Day Rate",
      "precision": "0",
      "in_list_view": 1,
      "description": "Editable. Whole rupees (no decimals) -- only the final Amount carries paisa-level precision. Changing this recalculates Amount."
    },
    {
      "fieldname": "amount",
      "fieldtype": "Currency",
      "label": "Amount",
      "in_list_view": 1,
      "description": "Auto-recalculated as SUM(band count x that band's configured fraction) x Per-Day Rate, whenever any band count or Per-Day Rate changes. You can also edit Amount directly -- one-way, does not push a value back into the band counts."
    },
    {
      "fieldname": "additional_salary",
      "fieldtype": "Link",
      "label": "Additional Salary (after processing)",
      "options": "Additional Salary",
      "read_only": 1
    }
  ],
  "permissions": []
}
